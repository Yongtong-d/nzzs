.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: #ffffff;
  padding-bottom: env(safe-area-inset-bottom);
}

.tabbar-line {
  height: 1rpx;
  background: #eaeaea;
}

.tabbar-content {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-text {
  font-size: 22rpx;
  line-height: 1;
  color: #888888;
}

.tab-text-active {
  color: #f4d35e;
}

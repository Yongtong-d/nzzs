.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  background: #f7f7f7;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.top-main {
  flex: 1;
}

.top-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #222222;
}

.top-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888888;
}

.outline-button,
.primary-button,
.action-button {
  margin: 0;
}

.outline-button::after,
.primary-button::after,
.action-button::after {
  border: 0;
}

.outline-button {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  border: 1rpx solid #eaeaea;
  background: #ffffff;
  color: #222222;
  font-size: 24rpx;
}

.core-entry-card,
.quick-card,
.state-card,
.order-card,
.error-box {
  background: #ffffff;
  border: 1rpx solid #eaeaea;
  border-radius: 16rpx;
}

.core-entry-card {
  padding: 28rpx 24rpx;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #222222;
}

.card-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #888888;
}

.primary-button {
  margin-top: 20rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 14rpx;
  background: #2f2f2f;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.quick-section,
.orders-section {
  margin-top: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222222;
}

.section-link {
  font-size: 24rpx;
  color: #888888;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.quick-card {
  min-height: 150rpx;
  padding: 22rpx;
  box-sizing: border-box;
}

.quick-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #222222;
}

.quick-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #888888;
}

.state-card {
  padding: 24rpx;
}

.state-text {
  font-size: 25rpx;
  line-height: 1.7;
  color: #888888;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.order-card {
  padding: 24rpx;
}

.order-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.pet-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #222222;
}

.service-type {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888888;
}

.status-tag {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.status-pending {
  background: #fdf6df;
  color: #a37a0f;
}

.status-accepted,
.status-serving,
.status-completed,
.status-cancelled {
  background: #f5f5f5;
  color: #666666;
}

.order-info {
  margin-top: 16rpx;
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: #888888;
}

.info-value {
  display: block;
  margin-top: 6rpx;
  font-size: 25rpx;
  color: #222222;
}

.order-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.action-button {
  height: 66rpx;
  line-height: 66rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid #eaeaea;
  background: #ffffff;
  color: #222222;
  font-size: 24rpx;
}

.error-box {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #fff7f7;
}

.error-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #b24343;
}

<view class="page">
  <view class="top-bar">
    <view class="top-main">
      <text class="top-title">{{texts.pageTitle}}</text>
      <text class="top-subtitle">{{texts.pageSubtitle}}</text>
    </view>
  </view>

  <view class="core-entry-card">
    <text class="card-title">{{texts.createTitle}}</text>
    <text class="card-desc">{{texts.createDesc}}</text>
    <button class="primary-button" bindtap="goCreateOrder">{{texts.createButton}}</button>
  </view>

  <view class="quick-section">
    <text class="section-title">{{texts.quickEntryTitle}}</text>
    <view class="quick-grid">
      <view class="quick-card" bindtap="goPublishedOrders">
        <text class="quick-title">{{texts.orderCenterTitle}}</text>
        <text class="quick-desc">{{texts.orderCenterDesc}}</text>
      </view>
      <view class="quick-card" bindtap="goServiceRecords">
        <text class="quick-title">{{texts.publishedTitle}}</text>
        <text class="quick-desc">{{texts.publishedDesc}}</text>
      </view>
      <view class="quick-card" bindtap="goMyReviews">
        <text class="quick-title">{{texts.reviewsTitle}}</text>
        <text class="quick-desc">{{texts.reviewsDesc}}</text>
      </view>
      <view class="quick-card" bindtap="goProfile">
        <text class="quick-title">{{texts.profileTitle}}</text>
        <text class="quick-desc">{{texts.profileDesc}}</text>
      </view>
    </view>
  </view>
</view>

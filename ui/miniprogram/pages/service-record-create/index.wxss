.page {
  height: 100vh;
  background: linear-gradient(180deg, #f7f9fc 0%, #edf2f7 100%);
}

.page-inner {
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.section-card,
.error-box {
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(31, 41, 55, 0.08);
}

.section-head {
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.form-item {
  margin-top: 20rpx;
}

.form-item:first-child {
  margin-top: 0;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.form-input,
.readonly-box,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
}

.form-input,
.readonly-box {
  min-height: 84rpx;
  padding: 0 24rpx;
}

.form-input {
  font-size: 26rpx;
  color: #111827;
}

.readonly-box {
  display: flex;
  align-items: center;
}

.readonly-text {
  font-size: 26rpx;
  color: #4b5563;
}

.form-textarea {
  min-height: 220rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #111827;
}

.image-box {
  overflow: hidden;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx dashed #cbd5e1;
}

.preview-image,
.image-placeholder {
  width: 100%;
  height: 280rpx;
}

.image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-placeholder-text {
  font-size: 26rpx;
  color: #6b7280;
}

.form-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.error-box {
  background: #fff4f4;
}

.error-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #d14343;
}

.action-bar {
  margin-top: 12rpx;
}

.submit-button {
  height: 92rpx;
  line-height: 92rpx;
  border: none;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #22c55e 0%, #0f9f61 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 28rpx rgba(15, 159, 97, 0.24);
}

.submit-button::after {
  border: 0;
}

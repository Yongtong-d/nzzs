<view class="page">
  <view class="top-bar">
    <view class="top-main">
      <text class="top-title">{{texts.pageTitle}}</text>
      <text class="top-subtitle">{{texts.pageSubtitle}}</text>
    </view>
  </view>

  <view class="core-entry-card">
    <text class="card-title">{{texts.createTitle}}</text>
    <text class="card-desc">{{texts.createDesc}}</text>
    <button class="primary-button" bindtap="goOrderHall">{{texts.pickupButtonText}}</button>
  </view>

  <view class="quick-section">
    <text class="section-title">{{texts.quickEntryTitle}}</text>
    <view class="quick-grid">
      <view class="quick-card" bindtap="goOrderHall">
        <text class="quick-title">{{texts.orderHallTitle}}</text>
        <text class="quick-desc">{{texts.orderHallDesc}}</text>
      </view>
      <view class="quick-card" bindtap="goTakenOrders">
        <text class="quick-title">{{texts.myTakenTitle}}</text>
        <text class="quick-desc">{{texts.myTakenDesc}}</text>
      </view>
      <view class="quick-card" bindtap="goServiceRecords">
        <text class="quick-title">{{texts.recordsTitle}}</text>
        <text class="quick-desc">{{texts.recordsDesc}}</text>
      </view>
      <view class="quick-card" bindtap="goProfile">
        <text class="quick-title">{{texts.profileTitle}}</text>
        <text class="quick-desc">{{texts.profileDesc}}</text>
      </view>
    </view>
  </view>
</view>
<custom-tab-bar />

.page {
  height: 100vh;
  background: linear-gradient(180deg, #f7f9fc 0%, #eef3f7 100%);
}

.page-inner {
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.timeline {
  position: relative;
  padding-left: 28rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 8rpx;
  bottom: 8rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: #d1d5db;
}

.timeline-item {
  position: relative;
  margin-bottom: 24rpx;
}

.timeline-dot {
  position: absolute;
  left: -18rpx;
  top: 26rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 0 8rpx rgba(34, 197, 94, 0.14);
}

.record-card,
.state-card,
.error-box {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(31, 41, 55, 0.08);
}

.record-head {
  margin-bottom: 18rpx;
}

.record-time {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.record-row {
  margin-top: 18rpx;
}

.record-row:first-child {
  margin-top: 0;
}

.record-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.record-value {
  display: block;
  font-size: 27rpx;
  line-height: 1.7;
  color: #374151;
}

.record-value-multiline {
  white-space: pre-wrap;
  word-break: break-all;
}

.record-row-image {
  margin-top: 20rpx;
}

.record-image {
  width: 100%;
  height: 280rpx;
  border-radius: 20rpx;
  background: #f3f4f6;
}

.state-card,
.error-box {
  margin-bottom: 24rpx;
}

.state-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #6b7280;
}

.error-box {
  background: #fff4f4;
}

.error-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #d14343;
}

.action-bar {
  margin-top: 12rpx;
}

.primary-button {
  height: 92rpx;
  line-height: 92rpx;
  border: none;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #22c55e 0%, #0f9f61 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 28rpx rgba(15, 159, 97, 0.24);
}

.primary-button::after {
  border: 0;
}

.page {
  height: 100vh;
  background: #f7f7f7;
}

.page-inner {
  padding: 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.section-card,
.error-box {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #eaeaea;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #222222;
}

.section-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #888888;
}

.field {
  margin-bottom: 20rpx;
}

.field-last {
  margin-bottom: 0;
}

.field-row {
  display: flex;
  gap: 14rpx;
}

.field-col {
  flex: 1;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #222222;
}

.field-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #888888;
}

.date-range-bar {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #eaeaea;
  background: #ffffff;
}

.date-range-picker {
  flex: 1;
  height: 84rpx;
  display: block;
  box-sizing: border-box;
  overflow: hidden;
}

.date-range-picker view {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
}

.date-range-picker-start {
  justify-content: center;
}

.date-range-picker-end {
  justify-content: center;
}

.date-range-text {
  width: 100%;
  font-size: 28rpx;
  line-height: 1.2;
  color: #222222;
  text-align: center;
}

.date-range-placeholder {
  color: #888888;
}

.date-range-arrow-icon {
  width: 40rpx;
  height: 16rpx;
  flex-shrink: 0;
}

.field-input,
.picker-field,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 12rpx;
  border: 1rpx solid #eaeaea;
  background: #ffffff;
  color: #222222;
}

.field-input,
.picker-field {
  min-height: 84rpx;
  padding: 0 20rpx;
  line-height: 84rpx;
  font-size: 28rpx;
}

.field-textarea {
  min-height: 170rpx;
  padding: 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.pet-image-box {
  width: 100%;
  height: 220rpx;
  border: 1rpx solid #eaeaea;
  border-radius: 12rpx;
  background: #fafafa;
  overflow: hidden;
}

.pet-image-preview {
  width: 100%;
  height: 100%;
}

.pet-image-placeholder {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #888888;
}

.address-card {
  border: 1rpx solid #eaeaea;
  border-radius: 12rpx;
  background: #fafafa;
  padding: 16rpx;
}

.address-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.address-tag {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  border-radius: 999rpx;
  color: #666666;
  background: #f1f1f1;
}

.address-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: #222222;
  word-break: break-word;
}

.address-placeholder {
  color: #888888;
}

.location-coord {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #888888;
}

.switch-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.switch-field .field-label {
  margin-bottom: 0;
}

.ghost-button {
  margin-top: 12rpx;
  height: 70rpx;
  line-height: 70rpx;
  border: 1rpx solid #eaeaea;
  border-radius: 12rpx;
  background: #ffffff;
  color: #222222;
  font-size: 24rpx;
}

.ghost-button::after,
.submit-button::after {
  border: 0;
}

.error-box {
  background: #fff7f7;
}

.error-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #d14343;
}

.submit-button {
  margin-top: 10rpx;
  margin-bottom: calc(10rpx + env(safe-area-inset-bottom));
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  border-radius: 14rpx;
  background: #2f2f2f;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

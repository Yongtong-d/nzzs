.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f7f9fc 0%, #eef3f7 100%);
}

.page-scroll {
  flex: 1;
  min-height: 0;
}

.page-inner {
  padding: 24rpx 24rpx 160rpx;
  box-sizing: border-box;
}

.profile-card,
.menu-card,
.error-box {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(31, 41, 55, 0.08);
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e5e7eb;
}

.profile-main {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.nickname {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.role-tag {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef6ff;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 600;
}

.menu-card {
  margin-top: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 100rpx;
  padding: 0 24rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.menu-item-last {
  border-bottom: 0;
}

.menu-title {
  font-size: 28rpx;
  color: #1f2937;
}

.menu-arrow {
  font-size: 30rpx;
  color: #9ca3af;
}

.error-box {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #fff4f4;
}

.error-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #d14343;
}

.bottom-bar {
  flex-shrink: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  margin-bottom: calc(100rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.logout-button {
  height: 92rpx;
  line-height: 92rpx;
  border: none;
  border-radius: 20rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 28rpx rgba(239, 68, 68, 0.22);
}

.logout-button::after {
  border: 0;
}

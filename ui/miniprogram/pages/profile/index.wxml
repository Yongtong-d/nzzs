<view class="page">
  <scroll-view class="page-scroll" scroll-y="true">
    <view class="page-inner">
      <view class="profile-card">
        <image class="avatar" src="{{user.avatar}}" mode="aspectFill"></image>
        <view class="profile-main">
          <text class="nickname">{{user.nickname}}</text>
          <text class="role-tag">{{currentRoleText}}</text>
        </view>
      </view>

      <view class="menu-card">
        <view class="menu-item" bindtap="goMyPublishedOrders">
          <text class="menu-title">{{texts.myPublishedOrders}}</text>
          <text class="menu-arrow">{{texts.arrowText}}</text>
        </view>
        <view class="menu-item" bindtap="goMyTakenOrders">
          <text class="menu-title">{{texts.myTakenOrders}}</text>
          <text class="menu-arrow">{{texts.arrowText}}</text>
        </view>
        <view class="menu-item menu-item-last" bindtap="goMyReviews">
          <text class="menu-title">{{texts.myReviews}}</text>
          <text class="menu-arrow">{{texts.arrowText}}</text>
        </view>
      </view>

      <view wx:if="{{errorMessage}}" class="error-box">
        <text class="error-text">{{errorMessage}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <button class="logout-button" bindtap="handleLogout">{{texts.logoutText}}</button>
  </view>
</view>

.page {
  height: 100vh;
  background: linear-gradient(180deg, #f7f9fc 0%, #eef3f7 100%);
}

.page-inner {
  padding: 24rpx;
  box-sizing: border-box;
}

.tabs-scroll {
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.tabs {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 24rpx;
}

.tab-item {
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(31, 41, 55, 0.08);
}

.tab-item-active {
  background: linear-gradient(135deg, #22c55e 0%, #0f9f61 100%);
}

.tab-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #4b5563;
}

.tab-item-active .tab-text {
  color: #ffffff;
}

.order-card,
.state-card,
.error-box {
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(31, 41, 55, 0.08);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.head-main {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.pet-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.service-type {
  font-size: 24rpx;
  color: #6b7280;
}

.status-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-pending {
  background: #fff4db;
  color: #b76a00;
}

.status-accepted {
  background: #e8f2ff;
  color: #1d4ed8;
}

.status-serving {
  background: #e6f9ef;
  color: #0f9f61;
}

.status-completed {
  background: #ecfdf3;
  color: #15803d;
}

.status-cancelled {
  background: #fff1f2;
  color: #dc2626;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 20rpx;
}

.info-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #374151;
}

.price-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #f97316;
}

.card-footer {
  margin-top: 24rpx;
}

.detail-button {
  height: 76rpx;
  line-height: 76rpx;
  border: none;
  border-radius: 18rpx;
  background: #eef6ff;
  color: #2563eb;
  font-size: 26rpx;
  font-weight: 600;
}

.detail-button::after {
  border: 0;
}

.state-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #6b7280;
}

.error-box {
  background: #fff4f4;
}

.error-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #d14343;
}

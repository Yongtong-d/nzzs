.page {
  height: 100vh;
  background: linear-gradient(180deg, #f6f8fb 0%, #edf2f7 100%);
}

.page-inner {
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.section-card,
.state-card,
.error-box {
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(31, 41, 55, 0.08);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.status-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-pending {
  background: #fff4db;
  color: #b76a00;
}

.status-accepted {
  background: #e8f2ff;
  color: #1d4ed8;
}

.status-serving {
  background: #e6f9ef;
  color: #0f9f61;
}

.status-completed {
  background: #ecfdf3;
  color: #15803d;
}

.status-cancelled {
  background: #fff1f2;
  color: #dc2626;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}

.info-item,
.info-row {
  margin-top: 16rpx;
}

.info-row:first-child {
  margin-top: 0;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

.info-value,
.price-value {
  display: block;
  margin-top: 8rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: #374151;
}

.multiline {
  white-space: pre-wrap;
  word-break: break-all;
}

.price-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #f97316;
}

.pet-image {
  width: 100%;
  height: 320rpx;
  margin-top: 12rpx;
  border-radius: 20rpx;
  background: #f3f4f6;
}

.record-button,
.primary-button {
  border: none;
}

.record-button::after,
.primary-button::after {
  border: 0;
}

.record-button {
  margin-top: 24rpx;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 18rpx;
  background: #eef6ff;
  color: #2563eb;
  font-size: 26rpx;
}

.action-bar {
  margin-top: 8rpx;
}

.primary-button {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #22c55e 0%, #0f9f61 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 28rpx rgba(15, 159, 97, 0.24);
}

.state-card {
  padding: 32rpx 24rpx;
}

.state-text {
  font-size: 26rpx;
  color: #6b7280;
}

.error-box {
  background: #fff4f4;
}

.error-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #d14343;
}

<scroll-view class="page-scroll" scroll-y type="list">
  <view class="page">
    <view class="hero">
      <text class="brand">NZZS AUTH</text>
      <text class="headline">微信登录与身份切换</text>
      <text class="summary">登录后默认拥有 owner 身份，可在角色页切换为 feeder，并实时查询当前身份。</text>
    </view>

    <view class="panel profile-panel">
      <view class="panel-header">
        <text class="panel-title">登录信息</text>
        <text class="role-badge">{{currentRole}}</text>
      </view>

      <view class="avatar-wrap">
        <button class="avatar-button" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
          <image class="avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
        </button>
        <text class="avatar-tip">点击头像更新微信头像</text>
      </view>

      <view class="field">
        <text class="field-label">昵称</text>
        <input wx:if="{{canIUseNicknameComp}}" type="nickname" class="field-input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameChange" />
        <input wx:else class="field-input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameChange" />
      </view>

      <view class="field">
        <text class="field-label">接口地址</text>
        <text class="field-endpoint">{{apiBaseUrl}}/auth/login</text>
      </view>

      <button class="primary-button" loading="{{loading}}" bindtap="submitLogin">立即登录</button>
      <button class="secondary-button" bindtap="goToRolePage">身份切换</button>
      <button class="ghost-button" bindtap="clearLoginState">清空本地状态</button>
    </view>

    <view class="panel status-panel">
      <text class="panel-title">当前状态</text>
      <text class="status-text">{{statusText}}</text>
      <view class="chip-row">
        <text class="chip">{{isLoggedIn ? '已登录' : '未登录'}}</text>
        <text class="chip">{{isNewUser ? '新用户' : '已有账号或未登录'}}</text>
      </view>
      <view wx:if="{{accessToken}}" class="token-box">
        <text class="field-label">JWT Token</text>
        <text class="token-text">{{accessToken}}</text>
      </view>
    </view>
  </view>
</scroll-view>

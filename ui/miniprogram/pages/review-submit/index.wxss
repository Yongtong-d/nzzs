.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f7f9fc 0%, #eef3f7 100%);
}

.page-scroll {
  flex: 1;
  min-height: 0;
}

.page-inner {
  padding: 24rpx 24rpx 160rpx;
  box-sizing: border-box;
}

.section-card,
.error-box {
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(31, 41, 55, 0.08);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.score-value {
  font-size: 24rpx;
  color: #f97316;
}

.star-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.star-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #d1d5db;
  box-shadow: inset 0 4rpx 10rpx rgba(255, 255, 255, 0.45);
}

.star-dot-active {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  box-shadow: 0 10rpx 18rpx rgba(245, 158, 11, 0.22);
}

.review-textarea {
  width: 100%;
  min-height: 260rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  border: 2rpx solid #e5e7eb;
  background: #f8fafc;
  font-size: 26rpx;
  line-height: 1.7;
  color: #111827;
}

.error-box {
  background: #fff4f4;
}

.error-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #d14343;
}

.bottom-bar {
  flex-shrink: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.submit-button {
  height: 92rpx;
  line-height: 92rpx;
  border: none;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #22c55e 0%, #0f9f61 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 28rpx rgba(15, 159, 97, 0.24);
}

.submit-button::after {
  border: 0;
}

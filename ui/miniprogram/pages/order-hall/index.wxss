.page {
  height: 100vh;
  background: linear-gradient(180deg, #f4f8fb 0%, #eaf1f7 100%);
}

.page-inner {
  padding: 24rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.filter-card,
.order-card,
.state-card,
.error-box {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(31, 41, 55, 0.08);
}

.filter-card {
  padding: 28rpx 24rpx;
}

.filter-head,
.section-head,
.order-top,
.order-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.section-subtitle,
.reload-link {
  font-size: 24rpx;
  color: #0f766e;
}

.filter-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.filter-item {
  display: flex;
  flex-direction: column;
}

.filter-label {
  margin-bottom: 12rpx;
  font-size: 25rpx;
  font-weight: 600;
  color: #374151;
}

.picker-field {
  min-height: 84rpx;
  padding: 0 22rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  font-size: 27rpx;
  color: #111827;
}

.filter-actions {
  margin-top: 18rpx;
}

.ghost-button,
.detail-button,
.accept-button {
  margin: 0;
  border: none;
}

.ghost-button::after,
.detail-button::after,
.accept-button::after {
  border: 0;
}

.ghost-button {
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #eef6ff;
  color: #2563eb;
  font-size: 24rpx;
}

.list-section {
  margin-top: 24rpx;
}

.state-card {
  margin-top: 18rpx;
  padding: 32rpx 24rpx;
}

.state-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #6b7280;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.order-card {
  padding: 28rpx 24rpx;
}

.order-main {
  flex: 1;
  padding-right: 18rpx;
}

.pet-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.pet-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.status-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-pending {
  background: #fff4db;
  color: #b76a00;
}

.status-accepted {
  background: #e8f2ff;
  color: #1d4ed8;
}

.status-serving {
  background: #e6f9ef;
  color: #0f9f61;
}

.status-completed {
  background: #ecfdf3;
  color: #15803d;
}

.status-cancelled {
  background: #fff1f2;
  color: #dc2626;
}

.info-row {
  margin-top: 18rpx;
}

.info-label {
  display: block;
  font-size: 23rpx;
  color: #9ca3af;
}

.info-value {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #374151;
}

.order-bottom {
  gap: 18rpx;
  margin-top: 24rpx;
}

.price-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #f97316;
}

.action-row {
  display: flex;
  gap: 12rpx;
}

.detail-button,
.accept-button {
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.detail-button {
  background: #1f2937;
  color: #ffffff;
}

.accept-button {
  background: linear-gradient(135deg, #22c55e 0%, #0f9f61 100%);
  color: #ffffff;
}

.accept-button[disabled] {
  background: #d1d5db;
  color: #ffffff;
}

.error-box {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #fff4f4;
}

.error-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #d14343;
}

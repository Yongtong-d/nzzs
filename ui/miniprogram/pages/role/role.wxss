page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(219, 200, 176, 0.3), transparent 30%),
    linear-gradient(180deg, #f8f4ed 0%, #f1eadf 100%);
  color: #201813;
}

.page {
  padding: 48rpx 28rpx 80rpx;
}

.hero {
  padding: 12rpx 4rpx 24rpx;
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  letter-spacing: 7rpx;
  color: #8e735c;
}

.title {
  display: block;
  margin-top: 16rpx;
  font-size: 58rpx;
  font-weight: 700;
  line-height: 1.15;
}

.subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #655649;
}

.card {
  margin-top: 24rpx;
  padding: 30rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 251, 245, 0.92);
  border: 1px solid rgba(84, 59, 38, 0.08);
  box-shadow: 0 18rpx 48rpx rgba(67, 50, 33, 0.08);
}

.name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
}

.current,
.hint,
.section-title {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #5b4b3f;
}

.section-title {
  margin-top: 0;
  font-weight: 600;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.role-button {
  border-radius: 999rpx;
  background: #ead9c4;
  color: #34261d;
  font-size: 30rpx;
}

.role-button::after {
  border: none;
}

.role-button-active {
  background: #201915;
  color: #fffaf5;
}
